@model IEnumerable<ElectricInventorySystem.Models.Supplier>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Suppliers</h2>

        @if (Context.Session.GetString("Role") == "Editor" || Context.Session.GetString("Role") == "Admin")
        {
            <a href="/Supplier/Create" class="btn btn-success">+ Add Supplier</a>
        }
    </div>

    <div class="row">

        <form method="get" class="mb-3 d-flex">
            <input type="text" name="search" class="form-control me-2" placeholder="Search supplier..." />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>

        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card supplier-card p-3 shadow mb-4">

                    <h4 class="text-primary">@item.Name</h4>

                    <p><b>📞 Phone:</b> @item.Phone</p>
                    <p><b>📧 Email:</b> @item.Email</p>
                    <p><b>📍 Address:</b> @item.Address</p>

                    <p>
                        <b>🕒 Created:</b>
                        @(item.CreatedAt.HasValue
                            ? item.CreatedAt.Value.ToString("dd-MM-yyyy hh:mm tt")
                            : "No Date")
                    </p>

                    <div class="mt-3 d-flex justify-content-between">

                        @if (Context.Session.GetString("Role") == "Editor" || Context.Session.GetString("Role") == "Admin")
                        {
                            <a href="/Supplier/Edit/@item.SupplierId" class="btn btn-warning btn-sm">Edit</a>
                        }

                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <a href="/Supplier/Delete/@item.SupplierId" class="btn btn-danger btn-sm">Delete</a>
                        }

                    </div>

                </div>
            </div>
        }

    </div>

</div>