@model ElectricInventorySystem.Models.Supplier

@if (Model == null)
{
    <h3 class="text-danger">Supplier not found</h3>
    <a href="/Supplier" class="btn btn-secondary">Back</a>
}
else
{
    <div class="container mt-4">
        <h2 class="text-danger">Delete Supplier</h2>

        <div class="card p-4 shadow">
            <h4>Are you sure you want to delete this?</h4>

            <p><b>Name:</b> @Model.Name</p>
            <p><b>Phone:</b> @Model.Phone</p>
            <p><b>Email:</b> @Model.Email</p>
            <p><b>Address:</b> @Model.Address</p>

            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="SupplierId" />

                <button type="submit" class="btn btn-danger">Delete</button>
                <a href="/Supplier" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
}