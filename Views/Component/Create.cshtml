@model ElectricInventorySystem.Models.Component

<div class="container mt-4">
    <h2 class="text-success">Add Component</h2>

    <form asp-action="Create" method="post" class="card p-4 shadow">
        <div class="mb-3">
            <label>Product Name</label>
            <input asp-for="ProductName" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Component Name</label>
            <input asp-for="ComponentName" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Part No</label>
            <input asp-for="PartNo" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Voltage</label>
            <input asp-for="Voltage" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Amp</label>
            <input asp-for="Amp" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Quantity</label>
            <input asp-for="Quantity" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Brand Name</label>
            <input asp-for="BrandName" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Location</label>
            <input asp-for="Location" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Component" class="btn btn-secondary">Back</a>
    </form>
</div>